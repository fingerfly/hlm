{
  "name": "hlm",
  "version": "5.3.1",
  "private": true,
  "type": "module",
  "description": "Huleme (HLM) - Guobiao Mahjong Fan Calculator.",
  "scripts": {
    "test": "npm run test:unit && npm run test:regression && npm run test:integration && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:unit": "node --test \"tests/unit/**/*.test.js\"",
    "test:regression": "node --test \"tests/regression/**/*.test.js\"",
    "test:integration": "node --test \"tests/integration/**/*.test.js\"",
    "build:dist": "node scripts/buildDist.js",
    "quality:complexity": "node scripts/quality-complexity.js",
    "perf:smoke": "node scripts/perf-smoke.js",
    "deploy": "node scripts/deploy.js",
    "release": "node scripts/deploy.js release",
    "release:build": "node scripts/deploy.js build --confirm",
    "release:patch": "node scripts/deploy.js patch --confirm",
    "release:minor": "node scripts/deploy.js minor --confirm",
    "release:major": "node scripts/deploy.js major --confirm",
    "release:doctor": "node scripts/deploy.js doctor",
    "prompt:update": "node scripts/deploy.js prompt-update",
    "prompt:release": "node scripts/deploy.js prompt-release",
    "prompt:all": "node scripts/deploy.js prompt-all",
    "prompt:update:agent": "node scripts/deploy.js prompt-update-agent",
    "prompt:release:agent": "node scripts/deploy.js prompt-release-agent",
    "prompt:update:agent:run": "node scripts/deploy.js prompt-update-agent --run-agent",
    "prompt:release:agent:run": "node scripts/deploy.js prompt-release-agent --run-agent"
  },
  "overrides": {
    "file-type": "^21.3.1"
  },
  "dependencies": {
    "jimp": "^1.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
